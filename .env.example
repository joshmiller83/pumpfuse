# Copy this to .env and fill in your values. Never commit .env.
# See README for how to discover these addresses.

UDM_SSH_HOST=          # alias from ~/.ssh/config, or IP of your network gateway
DEVICE_SUMP=           # IP of the sump pump ESP32 on your IoT VLAN
DEVICE_EJECTOR=        # IP of the ejector pit ESP32 on your IoT VLAN

# Gallons per minute estimates (override once you have measured data).
# Default: 36.7 GPM based on ~870W real power ≈ 1.2 HP → ~2,200 GPH.
GPM_SUMP=18.3
GPM_EJECTOR=18.3
